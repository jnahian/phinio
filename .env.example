# Database
# Pooled URL (contains -pooler in the hostname) — used by the app at runtime via PgBouncer
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Direct URL (no -pooler) — used by prisma migrate deploy, which requires a direct connection
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Better Auth
# Generate with: npx -y @better-auth/cli secret
BETTER_AUTH_SECRET="your-secret-here"
# Must match the deployed URL exactly — used in email verification and password reset links
BETTER_AUTH_URL="https://your-app.vercel.app"

# Resend (email)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# Must be a verified sender domain in your Resend account
RESEND_FROM="Phinio <noreply@yourdomain.com>"

# Web Push (browser notifications)
# Generate a pair with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# Must be a mailto: or https:// URI the browser can reach
VAPID_SUBJECT="mailto:you@example.com"
# Exposed to the client for PushManager.subscribe(). Must equal VAPID_PUBLIC_KEY.
VITE_VAPID_PUBLIC_KEY=""

# Cron endpoint secret (guards /api/cron/send-reminders)
# Generate with: openssl rand -hex 32
CRON_SECRET=""
